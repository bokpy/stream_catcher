def save_to_netscape_format(cookies, filename="cookies.txt"):
	with open(filename, "w", encoding="utf-8") as f:
		# Write the required Netscape header
		f.write("# Netscape HTTP Cookie File\n")
		f.write("# This file is generated by Python; edit at your own risk.\n\n")
		
		for domain, name, value, path, expiry_ms, secure_val in cookies:
			# 1. Determine if subdomains are included
			# Usually TRUE if the domain starts with a dot
			include_subdomains = "TRUE" if domain.startswith(".") else "FALSE"
			
			# 2. Convert Secure flag (1 or 0 to TRUE/FALSE)
			secure = "TRUE" if secure_val == 1 else "FALSE"
			
			# 3. Convert expiry from milliseconds to seconds
			expiry_s = str(int(expiry_ms // 1000))
			
			# 4. Format line: Domain, Subdomains, Path, Secure, Expiry, Name, Value
			# Use \t for tabs as per Linux standards
			line = "\t".join([
				domain,
				include_subdomains,
				path,
				secure,
				expiry_s,
				name,
				value
			])
			
			f.write(line + "\n")

def inspect_cookies_sqlite(db):
	shutil.copy2(db, "tmp.sqlite")  # Copy — Firefox locks the file
	conn = sqlite3.connect("tmp.sqlite")
	rows = conn.execute(
	"SELECT host, name, value, path, expiry, isSecure "
	"FROM moz_cookies WHERE host LIKE '%youtube%' OR host LIKE '%google%'"
	).fetchall()
	return rows

def system_locate(filename):
	"""
	Uses the Linux system 'locate' command for maximum speed.
	"""
	try:
		# Runs 'locate filename' and captures the output
		output = subprocess.check_output(["locate",'-b','-r', filename+'$' ])
		result = output.decode("utf-8")
		return result.strip().split("\n")
	except subprocess.CalledProcessError:
		# Return empty list if nothing is found
		return []
def find_cookies_sqlite():
	"""
	Searches the home directory for Firefox cookies.sqlite files.
	Returns a list of absolute paths.
	"""
	# Get the absolute path to the user's home directory
	home = pathlib.Path.home()
	
	# Define the search pattern
	# .mozilla/firefox/ is the standard location for Firefox profiles
	search_path = home / ".mozilla" / "firefox"
	
	# Check if the path exists first to avoid errors
	if not search_path.exists():
		print("Firefox directory not found.")
		return []

	# Use glob to find all cookies.sqlite files recursively within the firefox dir
	# '**' means search through all subdirectories (the profile folders)
	cookie_files = list(search_path.glob("**/cookies.sqlite"))
	return [str(path) for path in cookie_files]

