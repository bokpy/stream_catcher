async def worker(queue):
	"""Consumes URLs from the queue and downloads them."""
	while True:
		url = await queue.get()
		print(f'Download:     "{url}"')
		
		try:
			await asyncio.to_thread(download_sync, url)
		except Exception as e:
			print(f"Download failed: {e}")
		
		# Signal the queue that the task is done
		queue.task_done()
		print(f'Completed:    "{url}"')

async def clipboard_scanner(queue):
	"""Scans clipboard for new URLs."""
	global TAKE_FIVE,CLIPPED_URLS
	last_clip = ""
	print("Scanning clipboard... (Ctrl+C to stop)")
	while True:
		try:
			current_clip = get_clipboard()
			# Basic check to see if it's a new YouTube/Video link
			if current_clip != last_clip:
				#print(f'\nClipping :"{current_clip}"')
				url = get_stream_url_from_clip(current_clip)
				if url:
					if url in CLIPPED_URLS:
						print(f'Duplicate:    "{url}"')
					else:
						print(f'Queue stream: "{url}"')
						CLIPPED_URLS.add(url)
						await queue.put(url)
				last_clip = current_clip
		except Exception:
			pass
		
		await asyncio.sleep(TAKE_FIVE)  # Poll every TAKE_FIVE seconds

async def main():
	queue = asyncio.Queue()
	
	# Start the worker and the scanner as background tasks
	worker_task  = asyncio.create_task(worker(queue))
	scanner_task = asyncio.create_task(clipboard_scanner(queue))
	
	# Keep the script running
	await asyncio.gather(scanner_task)

