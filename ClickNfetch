def file_is_older(file_path, days=2):
	"""
	Returns True if the file at file_path was modified more than 'weeks' ago.
	"""
	path = pathlib.Path(file_path)
	
	if not path.exists():
		print(f"File not found: {file_path}")
		return False
	
	# Get the last modification time as a timestamp
	# .stat().st_mtime returns the time in seconds since the epoch
	mtime_timestamp = path.stat().st_mtime
	mtime_datetime = datetime.fromtimestamp(mtime_timestamp)
	
	cutoff = datetime.now() - timedelta(days=days)
	
	# If the modification time is earlier than the cutoff, it's old
	return mtime_datetime < cutoff

def get_stream_url_from_clip(line:str)->str:
	"""
	:param line: try to extract a video url from line
	:type line: str
	:return: url or ''
	:rtype: str
	"""
	match =youtube_re.search(line)
	if match:
		return match.group()
	match = youtu_be_re.search(line)
	if match:
		return match.group()
	match = m3u8_re.search(line)
	if match:
		return match.group()
	match = https_re.search(line)
	if match:
		return match.group()
	return ''

