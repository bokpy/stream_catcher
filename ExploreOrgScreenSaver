	def clip_show(S,url:str)->bool:
		"""
		run mpv with the given url
		:param url: an explore.org m3u8 url
		:type url: str
		:return: True is stream was displayed with success
		:rtype: bool
		"""
		global PATIENT_SECS
		
		print(f'options={MpvPlayer.options + [url]}')
		stop_time = time.time() + MpvPlayer.clip_length
		mpv_proc = subprocess.Popen(MpvPlayer.options + [url],stdout=subprocess.PIPE,stderr=subprocess.DEVNULL,text=True)
		time.sleep(PATIENTS_SECS)
		while time.time() < stop_time:
			if mpv_proc.poll():
				print(f'StreamDisplayer in run FAILED')
				return False
			for line in mpv_proc.stdout:
				print(line.strip())
			
			time.sleep(3)
		mpv_proc.terminate()
		return True
		
	def screen_mode_options(S):
		if args.mode:
			if args.mode == 'original':
				return
			if args.mode == 'stretch':
				MpvPlayer.options += ["--keepaspect=no"]
				return
			if args.mode == 'zoom':
				MpvPlayer.options += ["--video-zoom=1","--panscan=1.0"]
				return
			MpvPlayer.options += ["--keepaspect=no"]
		
