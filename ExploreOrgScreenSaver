def service_call(*args):
	try:
		info = subprocess.check_output(args)
	except subprocess.SubprocessError as e:
		print(f'{args} failed')
		print(f'is {args[0]} intalled?')
		print(f'subprocess.SubprocessError {e}')
		return None
	str_info = info.decode('utf-8')
	return str_info.splitlines()
	
def detect_monitors():
	"""
	use xrandr output to determine which monitors are conected and thier geometry
	:return: list of class Monitor
	:rtype: list[Monitor]
	"""
#HDMI-1 connected primary 3440x1440+0+0 (normal left inverted right x axis y axis) 797mm x 334mm
	detected = []
	xrandr = service_call('xrandr')
	for line in xrandr:
		if ' connected ' in line:
			print(f'{line}')
			detected.append(Monitor(line))
	return detected

class Clip(dict):
	STORED_GOOD = 0
	STORED_BAD  = 1
	NOT_STORED  = 2
	NEED_LOOKUP = 3

	STATUS = ['STORED_GOOD', 'STORED_BAD ', 'NOT_STORED', 'NEED_LOOKUP']

	def __init__(S,url,status):
		dict.__init__(S)
		S['url']=url
		S['status']=status
		S.birth = time.time()
		
	def __str__(S):
		return f'Clip("{S['url']}",{Clip.STATUS[S['status']]},{S.live_time(S):6.2f})'
	
	def status_str(S):
		return Clip.STATUS[S['status']]
		
	def live_time(S):
		return time.time() - S.birth
	
	def evaluate(S):
		if 'time' in S:
			return False
		if S['time'] < 5:
			return False

class Monitor:
	"""
	Holds the xrandr data of an active monitor
	geometry and name
	"""
	def __init__(S,xrandr_line):
		S.xrandr_line = xrandr_line
		S.name=xrandr_line.split()[0]
		match = re.findall(r'((\d+)x(\d+)\+(\d+)\+(\d+))',xrandr_line)
		
		S.geomety=match[0][0]
		S.w = int(match[0][1])
		S.h = int(match[0][2])
		S.x = int(match[0][3])
		S.y = int(match[0][4])
		
	def __str__(S):
		name = S.xrandr_line.split()[0]
		return f'monitor "{name}" at [{S.x:4},{S.y:4}]-[{(S.x+S.w):4},{(S.y+S.h):4}]'
	
class MpvOutput(dict):
	# (+) Video --vid=1 (h264 1920x1080 30.000fps)
    # (+) Audio --aid=1 (aac 2ch 44100Hz)
    #AO: [pipewire] 44100Hz stereo 2ch floatp
    #VO: [gpu] 1920x1080 yuv420p

	def __init__(S,txt):
		dict.__init__(S)
		val1 = val2 = False
		lines=txt.split('\n')
		for line in lines:
			if not val1:
				match = re.findall(r'Video [^(]+\((\S+) (\d\d\d*)x(\d\d\d*) ([\d.]*)',line)
				if match:
					val1 = True
					item = match[0]
					S['video_codec']=item[0]
					S['scrw']= int(item[1])
					S['scrh']= int(item[2])
					S['fps'] = int(item[3].replace('.',''))
			if not val2:
				match = re.findall(r'Audio [^(]+\((\S+) (\d+)ch (\d+)Hz',line)
				if match:
					val2 = True
					item = match[0]
					S['audio_codec']    = item[0]
					S['audio_channels'] = int(item[1])
					S['sample_rate']    = int(item[2])
			S['valid'] = val1 and val2
			if S['valid']:
				S.show()
				return
		
	def show(S):
		print(json.dumps(S,indent=4))

class Displayer:
	def __init__(S,monitor,url_db):
		S.monitor = monitor
		S.name = monitor.name
		S.db = url_db
		t = S.clip_length = args.clip_length
		S.options = ['mpv']
		S.add_screen_mode_options()
		S.add_xscreensaver_options()
		
	def add_screen_mode_options(S):
		if not args.mode:
			return
		if args.mode == 'original':
			return
		if args.mode == 'stretch':
			S.options += ["--keepaspect=no"]
			return
		if args.mode == 'zoom':
			S.options += ["--video-zoom=1", "--panscan=1.0"]
	
	def add_xscreensaver_options(S):
		if 'XSCREENSAVER_WINDOW' in os.environ:
			wid = str(os.environ['XSCREENSAVER_WINDOW'])
			S.options +=  [
			'--wid='+ wid
			,'-audio=no'
			,"-quiet"
			,"-hwdec=no"
			,"--geometry=" + S.monitor.geomety
			, '--length=' + str(int(args.clip_length))
			#,"-really-quiet"
			,"--fullscreen"
			]
			return
		S.options += [
			"--geometry=50%x50%"
			,'--length=10'
			]
			
class SocketMpv(Displayer):
	# https://mpv.io/manual/stable/#json-ipc
	def __init__(S,monitor,db):
		Displayer.__init__(S,monitor,db)
		S.socket_path = '/tmp/mpv-socket-'+ S.name
		print(f'{S.socket_path=}')
		S.name += ' socket'
		S.options += ['--input-ipc-server='+S.socket_path,'--idle']
		S.server_proc = subprocess.Popen(
			S.options + [CONFIG_DIR + "intro.mp4"],
			stdout=subprocess.PIPE,stderr=subprocess.STDOUT
		)
		time.sleep(1)
		S.dt_check = .8 # polling interval
		S.request_id = 0
		atexit.register(S.say_bye)
		
	async def preform(S):
		on_display = None
		
		while True:
			if on_display and on_display.live_time() > args.clip_length:
				print(f'To old {on_display.live_time():6.2f} sec')
			res = S.send_command("get_property", "idle-active")
			await asyncio.sleep(S.dt_check)
			if isinstance(res,list):
				ic(res)
				continue
			if 'data' in res:
				if res["data"]:  # is idle
					if on_display and on_display['status']==Clip.NOT_STORED:
						S.db.assess(on_display)
						await asyncio.sleep(1)
					on_display = S.db.pick_random_url()
					S.send_command('loadfile', on_display['url'], 'replace')
					await asyncio.sleep(1)
				continue
			if on_display and not 'data' in on_display:
				S.ask_stream_info(on_display)
			print (f'No data res "{res}"')
			
	def ask_stream_info(S,clip):
		tracks = S.send_command("get_property", "track-list")
		ic(tracks)
		vo = S.send_command("get_property", "current-vo")
		ic(vo)
		ao = S.send_command("get_property", "current-ao")
		ic(ao)
		metadata = S.send_command("get_property", "filtered-metadata")
		ic(metadata)
		clip['data'] = {'tracks':tracks,'vo':vo,'ao':ao,'metadata':metadata}
		
	def say_bye(S):
		print(f'SocketMpv({S.name}) says bye.' )
		if S.server_proc:
			print ( f'close mpv process at "{S.socket_path}"')
			S.server_proc.terminate()
			os.remove(S.socket_path)
		S.server_proc=None
		
	def is_on_socket(S):
		return True
	
	def send_command(S, *args):
		"""Formats and sends a JSON command to the mpv socket."""
		if not os.path.exists(S.socket_path):
			print(f"Error: Socket {S.socket_path} not found. Is mpv running?")
			return None
		
		# Build the JSON payload
		S.request_id += 1
		payload = {"command": list(args), "request_id": S.request_id }
		
		# Connect to the Unix Domain Socket
		with (socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client):
			client.connect(S.socket_path)
			client.sendall((json.dumps(payload) + '\n').encode('utf-8'))
			
			# Receive response (mpv sends a JSON response for every command)
			response = client.recv(4096)
			ret_str=response.decode('utf-8').strip()
			#ic(ret_str)
			try:
				ret_json=json.loads(ret_str)
				return ret_json
			except JSONDecodeError as e:
				print(f'{ret_str =}')
				ic(e)
			ret_list = '['+ ret_str.replace('\n',',') + ']'
			ic(ret_list)
			try:
				ret = json.loads(ret_list)
				ic(ret)
				return ret
			except JSONDecodeError as e:
				print(f'{ret_str =}')
				ic(e)
			return {'json_loads_failed':ret_str}
	
class MpvPlayer(Displayer):
	
	def __init__(S,monitor):
		Displayer.__init__(S,monitor)
		print (f'{S.options=}')
	
	def is_on_socket(S):
		return False
		
	def precent_error(S, e_txt):
		if 'rror 403' in e_txt:
			print('Error 403: Forbidden')
			return
	
		for line in e_txt.split('\n'):
			print(f'\t{line}')
		
	async def show_clip(S,url_dict):
		
		command = ' '.join(S.options + [url_dict['url']] )
		print(f'command : {command}',end=' ')
		mpv_proc = subprocess.Popen(S.options + [url_dict['url']],stdout=subprocess.PIPE,stderr=subprocess.PIPE,text=True)
		_patience = 0.0
		_tik = S.patients_secs / 200
		while _patience < S.patients_secs:
			await asyncio.sleep(_tik)
			_patience += _tik
			if mpv_proc.poll():
				print(f'{mpv_proc.returncode} after {_patience} sec.')
		
		_count_up = 0.0
		while _count_up < S.clip_length:
			check = mpv_proc.poll()
			if check:
				# print(f'FAILED at {_count_down} error {check} code {mpv_proc.returncode}')
				S.precent_error(mpv_proc.stderr.read())
				url_dict['error']=mpv_proc.returncode
				url_dict['error_text'] = mpv_proc.stderr.read()
				url_dict['time'] =_count_up
				mpv_proc.terminate()
				return url_dict
			await asyncio.sleep(S.patients_secs)
			_count_up += S.patients_secs
		mpv_proc.terminate()
		url_dict['error']=0
		url_dict['data'] = mpv_proc.stdout.read()
		url_dict['time'] =_count_up
		print ("Success")
		return url_dict

	async def preform(S):
		print (f'{S.name =} end')
	
