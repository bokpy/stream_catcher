		print(f'{S.socket_path=}')
		S.set_options(Xgeo)
		S.server_proc = S.start_server()
		S.dt_check = .8  # polling interval
		S.name = 'MSP-'+S.id
		atexit.register(S.kill_me)
		
	def start_server(S):
		proc = subprocess.Popen(
			S.options
			, stdin =subprocess.DEVNULL
			, stdout=subprocess.DEVNULL
			, stderr=subprocess.DEVNULL
			)
		time.sleep(1)
		return proc
	
	def kill_me(S):
		if S.server_proc:
			S.server_proc.terminate()
			print(f'{S.name} terminated')
			time.sleep(1)
			S.server_proc=None
	
