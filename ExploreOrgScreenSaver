async def aio_command(socket_path,responce_test, *args):
	# 1. Establish the async connection
	reader, writer = await asyncio.open_unix_connection(socket_path)
	
	try:
		# 2. Prepare and send the command
		command = {"command": list(args), "request_id": 100}
		writer.write((json.dumps(command) + "\n").encode())
		await writer.drain()  # Ensure the data is sent
		
		# 3. Read the stream asynchronously
		while True:
			# This line does not block the entire program
			line_bytes = await reader.readline()
			if not line_bytes:
				break
			
			data = json.loads(line_bytes.decode())
			# ic(data)
			#
			# Handle the response logic
			if data.get("request_id") == 100:
				if data.get("error") != "success":
					print(f"Error: {data['error']}")
					return False
			
			if data.get("event") == responce_test:
				print(f'Success event:"{responce_test}"')
				return True
			
			if data.get("event") == "end-file" and data.get("reason") == "error":
				print(f'Failed: "{responce_test}"')
				return False
	
	finally:
		writer.close()
		await writer.wait_closed()

