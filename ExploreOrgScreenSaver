class HeartbeatCheck:
	def __init__(S,pulse):
		S.pulse=pulse
		S.clients = {}
		
	def checkup(S,name):
		S.clients[name]=time.time()
		
	async def pacemaker(S):
		while True:
			now = time.time()
			for name, last_seen in S.clients.items():
				latency = now - last_seen
				if latency > S.pulse:
					print(f"CRITICAL: {name} is HANGING! (Last seen {latency:.2f}s ago)")
				else:
					print(f"{name}",end='')
			await asyncio.sleep(2)
			
async def main():
	# main
	url_db     = ExploreOrgDb()
	drHeart    = HeartbeatCheck(4)
	monitors   = detect_monitors()
	tasks      = [MpvDisplayer(monitor,url_db,drHeart).preform() for monitor in monitors]
	tasks.append(drHeart.pacemaker())
	group = asyncio.gather(*tasks)
	try:
		await group
	except Exception as e:
		print(f'Task failure: {e}')
		for task in tasks:
			task.cancel()
	await asyncio.sleep(2)
	print (f'Clean END reached bye')
	
