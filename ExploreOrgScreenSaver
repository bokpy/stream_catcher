class MpvSocketPlayer:
	
	def __init__(S,Xgeo):
		S.name = get_an_id()
		print(f'MpvSocketPlayer({S.name},{Xgeo})')
		S.socket_path = '/tmp/mpv-socket-' + S.name
		print(f'{S.socket_path=}')
		S.set_options(Xgeo)
		S.server_proc = S.start_server()
		
		S.dt_check = .8  # polling interval
		S.name += 'MSP-'+S.name
		
	def start_server(S):
		subprocess.Popen(
			S.options
		#	+ [CONFIG_DIR + "intro.mp4"]
			, stdout=subprocess.PIPE
			, stderr=subprocess.STDOUT
			)
		time.sleep(1)
		S.send_command("observe_property", 1, "idle-active")  # Example of a single track
		# Or better, tell mpv to be quiet:
		#{"command": ["set_property", "input-ipc-server", "yes"]}
	
	def set_options(S,Xgeo):
		S.options=['mpv'
			,'--input-ipc-server='+S.socket_path
			, '--idle'
		]
		# screen mode options set by program arguments
		if args.mode == 'original':
			pass
		elif args.mode == 'stretch':
			S.options += ["--keepaspect=no"]
		elif args.mode == 'zoom':
			S.options += ["--video-zoom=1", "--panscan=1.0"]
		# options if running as xscreensaver hack
		if 'XSCREENSAVER_WINDOW' in os.environ:
			wid = str(os.environ['XSCREENSAVER_WINDOW'])
			S.options += [
				'--wid=' + wid
				, '-audio=no'
				, "-quiet"
				, "-hwdec=no"
				, "--geometry=" + Xgeo
				, '--length=' + str(int(args.clip_length))
				# ,"-really-quiet"
				, "--fullscreen"]
			return
		S.options += [
			"--geometry=50%x50%"
			,'--length=10'
		]

	def send_command(S,*args):
		def jsonify_response(r):
			s = r.decode('utf-8').strip()
			r_list = '[' + s.replace('\n', ',') + ']'
			try:
				return json.loads(r_list)
			except json.JSONDecodeError as e:
				print(e)
				ic(r_list)
				raise
			
		if not os.path.exists(S.socket_path):
			print(f"Error: Socket {S.socket_path} not found. Is mpv running?")
			return None
		
		#S.request_id += 1
		#payload = {"command": list(args), "request_id": S.request_id }
		payload = {"command": list(args)}
		try:
			with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
				client.connect(S.socket_path)
				client.settimeout(5.0)
				payload_bytes = (json.dumps(payload) + '\n').encode('utf-8')
				client.sendall(payload_bytes)
		
				# If the server is silent, this will now raise socket.timeout
				# instead of hanging the entire script.
				return jsonify_response(client.recv(4096))
			
		except socket.timeout as e:
			print(f"\nThe server {S.name} took too long to respond.")
			ic(e)
			return [{'error':'ExploreOrgScreenSaver.send_command() TimeoutError'}]
		except Exception as e:
			print(f"\nServer {S.name}: {e}")
			ic(e)
			raise
			
	
		
	async def display(S,q):
		while True:
			clip = await q.get()
			S.send_command('loadfile', clip['url'], 'replace')
			running=True
			while running:
				await asyncio.sleep(1.5)
				rdl = S.send_command("get_property", "idle-active")
				for rd in rdl:
					if 'data' in rd:
						running= not rd['data']
						if (not 'data' in clip) and running:
							S.ask_stream_info(clip)
			q.task_done()
			clip.signoff()
			
	def ask_stream_info(S,clip):
		tracks = S.send_command("get_property", "track-list")
		clip['data'] = tracks
		
class UrlProducer:

	table = """
		CREATE TABLE IF NOT EXISTS streams (
			url    TEXT PRIMARY KEY,
			tag    INTEGER DEFAULT -1,
			good   INTEGER DEFAULT 1,
			width  INTEGER DEFAULT 0,
			height INTEGER DEFAULT 0,
			time   TIMESTAMP DEFAULT CURRENT_TIMESTAMP
		);"""
	
	def __init__(S):
		S.createdb_if_needed()
		S.fill_tombola()

	def db_connect(S):
		conn = sqlite3.connect(EXPLORE_ORG_DB)
		cursor = conn.cursor()
		return conn, cursor
	
	def get_max_tag(S):
		try:
			conn, cursor = S.db_connect()
	
			query = """
			SELECT * FROM streams
			WHERE good = 1
			ORDER BY tag DESC
			LIMIT 1;
			"""
			
			cursor.execute(query)
			record = cursor.fetchone()
			
			if record:
				return list(record)[0]
			else:
				return "No records found matching the criteria."
		
		except sqlite3.Error as e:
			ic(e)
			return 100
		finally:
			if conn:
				conn.close()
		#
		# # Usage
		# database = 'your_database.db'
		# result = get_highest_tag_record(database)
		# print(result)
	
	def fill_tombola(S):
		# reg = re.compile(r'-(\d+)/\.')
		
		tombola_set = set()
		S.good_set = set()
		S.bad_set = set()
		
		def make_set(value=True,field='good'):
			ret_set = set()
			with sqlite3.connect(EXPLORE_ORG_DB) as con:
				cursor = con.cursor()
				query=f"SELECT url FROM streams WHERE {field}=?"
				try:
					cursor.execute(query, (value,))
					rows = cursor.fetchall()
					#print(rows)
				except sqlite3.OperationalError as e:
					print(e)
			
			for url_tuple in rows:
				url = url_tuple[0]
				if not url:
					continue
				ret_set.add(Explore(url).__int__())
			return ret_set
		
		tag_limit = S.get_max_tag() + 100
		S.bad_set  = make_set(False)
		S.tombola = [x for x in range(1,tag_limit) if x not in S.bad_set]
		S.max_pick = len(S.tombola)-1
		
	async def fill_queue(S,q):
		await q.put(Clip(-1,S.assess,CONFIG_DIR+'intro.mp4'))
		while True:
			if q.full():
				await asyncio.sleep(2)
				continue
			index = random.randint(0, S.max_pick)
			clip=Clip(S.tombola[index],S.assess)
			print(f'[Q{clip['tag']:04d}]',end='')
			await q.put(clip)

	def assess(S,clip):
		print(f'assess({clip["tag"]})')
		if clip.age() < 5.0:
			S.store_bad_status(clip)
			return
		S.store_good_status(clip)
		
	def store_good_status(S,clip)->None:
		# tag , url , good, width , heigh , time
		clip.extract_info()
		width  = clip['width']
		height = clip['height']
		now=time.time()
		#def upsert_stream(db_path, url, tag):
		# Connect to the SQLite database
		conn = sqlite3.connect(EXPLORE_ORG_DB)
		cursor = conn.cursor()
		
		try:
			# SQLite Upsert syntax (requires SQLite 3.24.0+)
			# url must be defined as the PRIMARY KEY for this to work
			sql = """
			INSERT INTO streams (tag, url, good, width, height, time)
			VALUES (?, ?, ?, ?, ?, ?)
			ON CONFLICT(url) DO UPDATE SET
				tag = excluded.tag, good=excluded.good,  width=excluded.width, height=excluded.height, time=excluded.time;
			"""
			cursor.execute(sql, (clip['tag'],clip['url'],True,width,height,now))
			conn.commit()
			print(f"\n+{clip['tag']} ")
		
		except sqlite3.Error as e:
			print(f"An error occurred: {e}")
			conn.rollback()
		
		finally:
			conn.close()

	def store_bad_status(S,clip)->None:
		# tag , url , good, width , heigh , time
		now=time.time()
		#def upsert_stream(db_path, url, tag):
		# Connect to the SQLite database
		conn = sqlite3.connect(EXPLORE_ORG_DB)
		cursor = conn.cursor()
		
		try:
			# SQLite Upsert syntax (requires SQLite 3.24.0+)
			# url must be defined as the PRIMARY KEY for this to work
			sql = """
			INSERT INTO streams (tag, url, good, time)
			VALUES (?, ?, ?, ?)
			ON CONFLICT(url) DO UPDATE SET
				tag = excluded.tag, good=excluded.good, time=excluded.time;
			"""
			cursor.execute(sql, (clip['tag'],clip['url'],False,now))
			conn.commit()
			print(f"\n-{clip['tag']}")
		
		except sqlite3.Error as e:
			print(f"An error occurred: {e}")
			conn.rollback()
		
		finally:
			conn.close()
		
	def url_status_lookup(S,url)->int:
		"""
		Look the url up in the database store result in S.lookup
		:param clip: with url to look up
		:type clip: Clip
		:return: a Clip STATUS
		:rtype: int
		"""
		
		with sqlite3.connect(EXPLORE_ORG_DB) as conn:
			cursor = conn.cursor()
			cursor.execute("SELECT * FROM streams WHERE url=?", (url,))
			row = cursor.fetchone()
		if not row:
			return Clip.NOT_STORED
		if row[1] == True: # the "good" field
			return Clip.STORED_GOOD
		return Clip.STORED_BAD
		
	def createdb_if_needed(S):
		if not os.path.isdir(CONFIG_DIR):
			try:
				os.mkdir(CONFIG_DIR)
			except OSError as e:
				print(f'Could not make dir "{CONFIG_DIR}".')
				print(e)
				exit(e.errno)
		try:
			con = sqlite3.connect(EXPLORE_ORG_DB)
			print(f'Opened "{EXPLORE_ORG_DB}" SQLite database\nwith version {sqlite3.sqlite_version} successfully.')
		except sqlite3.OperationalError as e:
			print(f'"Failed to open "{EXPLORE_ORG_DB}"')
			print(e)
			exit(1)
		cur = con.cursor()
		cur.execute(UrlProducer.table)
		con.close()
		
