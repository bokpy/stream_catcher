		else:
			S['tag'],S['url'] = Explore(tag).int_str()

	def clock_in(S):
		S['clock_in'] = time.time()
		
	def clock_out(S):
		S['clock_out'] = time.time()
		
	def work_time(S):
		if ( not 'clock_in' in S ) or (not 'clock_out' in S):
			return 0
		return S['clock_out'] - S['clock_in']
	
	def stint(S):
		if not 'clock_in' in S:
