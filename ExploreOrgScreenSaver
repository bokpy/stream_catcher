class ExploreOrgStream:
	url_base = "https://outbound-production.explore.org/stream-production-"
	url_tail = "/.m3u8"
	explore_dir = CONFIG_DIR + "explore.org/"
	tested_urls_file = explore_dir + "tested.json"
	displayer = None
	
	def __init__(S,displayer):
		ExploreOrgStream.displayer = displayer
		S.pick = -1
		if not os.path.isdir(ExploreOrgStream.explore_dir):
			try:
				os.mkdir(ExploreOrgStream.explore_dir)
			except OSError as e:
				print(f'could not make dir "{ExploreOrgStream.explore_dir}"')
				exit(e.errno)
		
		S.tested={}
		if os.path.isfile(ExploreOrgStream.tested_urls_file):
			try:
				with open(ExploreOrgStream.tested_urls_file,"r") as json_file:
					S.tested = json.load(json_file)
			except OSError as e:
				print(f'Reading "{ExploreOrgStream.tested_urls_file}" failed.')
				print(f'{e}')
				exit(e.errno)
		atexit.register(S.store_tested)
				
	def url_str(S):
		return S.url_base+ str(S.pick) + S.url_tail
	
	def store_tested(S):
		print(f'store_tested() Save test data')
		was_tested={}
		if os.path.isfile(ExploreOrgStream.tested_urls_file):
			try:
				with open(ExploreOrgStream.tested_urls_file,"r") as json_file:
					was_tested = json.load(json_file)
			except OSError as e:
				print(f'Reading "{ExploreOrgStream.tested_urls_file}" failed.')
				print(f'{e}')
				exit(e.errno)
		save_tested = was_tested | S.tested
		#print(json.dumps(save_tested,indent=2))
		with open(ExploreOrgStream.tested_urls_file,"w") as json_file:
			try:
				json.dump(save_tested,json_file,indent=4)
			except OSError as e:
				print(f'Failed to save data to "{ExploreOrgStream.tested_urls_file}"')
				print(e)
		
	def pick_a_nice_stream(S):
		global MAX_PICK
		while True:
			S.pick = random.randint(0,MAX_PICK) + 1
			print(f'{S.pick=}')
			if not S.pick in S.tested : # not tested try to runit
				return S.url_str()
			if S.tested[S.pick]['good']:
				return S.tested[S.pick]['url']
	
	def run(S):
		while True:
			url = S.pick_a_nice_stream()
			print(f'run shows "{url}"')
			ok = ExploreOrgStream.displayer.clip_show(url)
			S.tested[S.pick] = {'url':url,'good':ok}
	
