class Explore:
	num_reg = re.compile(r'-(\d+)/\.')
	def __init__(S,url):
		if isinstance(url,str):
			S.string  = url
			if 'intro.' in url:
				S.integer = -1
				return
			match = Explore.num_reg.findall(url)
			if not match or not len(match):
				ic(url)
				exit(234)
			S.integer = int(match[0])
			return
		S.string  = "https://outbound-production.explore.org/stream-production-" + str(url) + "/.m3u8"
		S.integer = url

	def int_str(S):
		return S.integer,S.string

	def __str__(S):
		return S.string

	def __int__(S):
		return S.integer
	
def service_call(*args):
	try:
		info = subprocess.check_output(args)
	except subprocess.SubprocessError as e:
		print(f'{args} failed')
		print(f'is {args[0]} intalled?')
		print(f'subprocess.SubprocessError {e}')
		return None
	str_info = info.decode('utf-8')
	return str_info.splitlines()

def get_monitor_geometries(divw=0,divh=0):
	"""
	use xrandr to get the geometry of the connected monitors
	HDMI-1 connected primary 3440x1440+0+0 (normal left inverted right x axis y axis) 797mm x 334mm
	:return: list of str of form 3440x1440+0+0
	:rtype: list[str]
	"""
	
	def devide(dw, dh,width, heigth):
		border = 30
		width, heigth = int(width), int(heigth)
		div_width  = width  // dw
		div_heigth = heigth // dh
		res = []
		for i in range(0, dw):
			for j in range(0, dh):
				t = (div_width-border, div_heigth-border, i * div_width, j * div_heigth)
				res.append(t)
		r = [str(x[0]) + 'x' + str(x[1]) + '+' + str(x[2]) + '+' + str(x[3]) for x in res]
		return r
	
	detected = []
	xrandr = service_call('xrandr')
	for line in xrandr:
		if ' connected ' in line:
			print(f'{line}')
			match = re.findall(r'((\d+)x(\d+)\+(\d+)\+(\d+))', line)
			detected.append(match[0][0])
	if divw == 0 and divh == 0:
		return detected
	if divw == 0:
		divw = 1
	elif divh == 0:
		divh = 1
	return devide(divw, divh, match[0][1], match[0][2])

def check_for_key(obj, key,on_fail=None):
	todo=[obj]
	while len(todo):
		cur = todo.pop()
		if isinstance(cur,dict):
			for k, v in cur.items():
				if k == key:
					return v
				if isinstance(v, dict) or isinstance(v, list):
					todo.append(v)
		if isinstance(cur,list):
			for c in cur:
				todo.append(c)
	return on_fail

def check_for_value(items,value):
	if isinstance(items,dict):
		for i in items.values():
			if i == value:
				return True
		return False
	try:
		for item in items:
			if check_for_value(item,value):
				return True
	except TypeError:
		ic(items)
		print (f'Is no dict nor iterable.')
	return False

def ct(flt):
	return f'{int(flt *10 % 100000):05d}'

class Clip:
	
	def __init__(S,tag,url=None):
		if url :
			S.tag=int(tag)
			S.url=url
		else:
			S.tag,S.url = Explore(tag).int_str()
			
		S.born = time.time()
		S.stint = 0.0
		S.height = S.width = 0
		
	def __str__(S):
		return f'Clip( {S.tag:04d}) stint: {ct(S.stint)}  {S.width}x{S.height}'

	def time_stint(S, val):
		S.stint += val
		
async def aio_communicate(socket_path,request_id, *args):
	# 1. Establish the async connection
	try:
		reader, writer = await asyncio.open_unix_connection(socket_path)
	except Exception as e:
		ic(socket_path,e)
		exit(257)
	
	try:
		# 2. Prepare and send the command
		command = {"command": list(args), "request_id": request_id}
		writer.write((json.dumps(command) + "\n").encode())
		await writer.drain()  # Ensure the data is sent
		
		# 3. Read the stream asynchronously
		while True:
			# This line does not block the entire program
			bytes = await reader.read(2048)
			if not bytes:
				break
			if bytes:
				deco = bytes.decode()
				d = deco.split("\n")
				ret = [ json.loads(i) for i in d if i]
				#print(f'{ret=}')
				return ret
			return False
	
	finally:
		#empty_socket_buffer(writer)
		writer.close()
		await writer.wait_closed()

