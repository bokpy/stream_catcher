class MpvSocketPlayer:
	
	def __init__(S,Xgeo):
		global IS_HACK
		S.id = get_an_id()
		print(f'MpvSocketPlayer({S.id},{Xgeo})')
		hack = 'H' if IS_HACK else 'T'
		S.socket_path = '/tmp/mpv-socket-' + S.id + hack
		print(f'{S.socket_path=}')
		S.set_options(Xgeo)
		S.server_proc = S.start_server()
		S.dt_check = .8  # polling interval
		S.name = 'MSP-'+S.id
		atexit.register(S.kill_me)
		
	def start_server(S):
		ic(S.options)
		try:
			proc = subprocess.Popen(
				S.options
				, stdin =subprocess.DEVNULL
				, stdout=subprocess.DEVNULL
				, stderr=subprocess.DEVNULL
				)
		except Exception as e:
			ic(e)
			exit(340)
			
		ok=False
		for _ in range(5):
			time.sleep(.4)
			ok = proc.poll() == None
			if ok:
				break
		
		if ok == False:
			print(f'Proc still born with {proc.returncode} ')
			exit(347)
		return proc
	
	def kill_me(S):
		if S.server_proc:
			S.server_proc.terminate()
			print(f'{S.name} terminated')
			time.sleep(1)
			S.server_proc=None
	
	def set_options(S,Xgeo):
		global SOUND
		S.options=['mpv'
			,'--input-ipc-server='+S.socket_path
			, '--idle'
		]
		# screen mode options set by program arguments
		if args.mode == 'original':
			pass
		elif args.mode == 'stretch':
			S.options += ["--keepaspect=no"]
		elif args.mode == 'zoom':
			S.options += ["--video-zoom=1", "--panscan=1.0"]
		# options if running as xscreensaver hack
		if IS_HACK:
			if args.sound and not SOUND:
				SOUND=True
			else:
				S.options += ['--audio=no']
				
			wid = str(os.environ['XSCREENSAVER_WINDOW'])
			S.options += [
				 "-quiet"
				 ,'--wid=' + wid
			 	 ,"--geometry=" + Xgeo
			 	#,"-hwdec=no"
			# 	#, '--length=' + str(int(args.clip_length))
			# 	# ,"-really-quiet"
			# 	, "--fullscreen"
			 ]
			return
		S.options += [
			"--keepaspect=no"
			, "--geometry=" + Xgeo
			, "--no-border"
			#"--geometry=50%x50%"
			#,'--length=10'
		]

	async def ask_stream_info(S,clip):
		if clip.width + clip.height > 0:
			return
		info = await aio_communicate(S.socket_path,STREAMINFO_REQUEST,"get_property", "track-list")
		ic(info)
		clip.width  = check_for_key(info,'demux-w',0)
		clip.height = check_for_key(info,'demux-h',0)
		ic(clip.width,clip.height)
		
	async def display(S, q):
		
		def check_is_idle(report):
			#[{'data': False, 'request_id': 100, 'error': 'success'}]
			r = report[0]
			if r.get('request_id') != IDLE_REQUEST:
				return False
			if r.get('error') != 'success':
				return False
			# if r.get('data'):
			# 	print (f'check_is_idle -> TRUE')
			return  r.get('data')
		
		while True:
			clip = await q.get()
			print(f'STARTING: {clip}')
			start = await aio_communicate(S.socket_path,RUNNING_REQUEST,'loadfile', clip.url, 'replace')
			ic(start,check_for_value(start,"success"))
			if not check_for_value(start,"success"):
				q.task_done()
				print(f'NON START: {clip}')
				await assess(clip)
				continue
			stoptime=time.time() + args.clip_length
			dt = 1.2
			while time.time()  <  stoptime:
				await asyncio.sleep(dt)
				await S.ask_stream_info(clip)
				clip.time_stint( dt)
				idle = await aio_communicate(
					S.socket_path, IDLE_REQUEST
					, "get_property", "idle-active")
				if check_is_idle(idle):
					print(f'IDLE STOP: {clip}')
					break
			q.task_done()
			print(f'FINNISH: {clip}')
			await assess(clip)

