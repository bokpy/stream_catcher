class Explore:
	num_reg = re.compile(r'-(\d+)/\.')
	def __init__(S,url):
		if isinstance(url,str):
			S.string  = url
			if 'intro.' in url:
				S.integer = -1
				return
			match = Explore.num_reg.findall(url)
			if not match or not len(match):
				ic(url)
				exit(234)
			S.integer = int(match[0])
			return
		S.string  = "https://outbound-production.explore.org/stream-production-" + str(url) + "/.m3u8"
		S.integer = url

	def int_str(S):
		return S.integer,S.string

	def __str__(S):
		return S.string

	def __int__(S):
		return S.integer
	
def service_call(*args):
	try:
		info = subprocess.check_output(args)
	except subprocess.SubprocessError as e:
		print(f'{args} failed')
		print(f'is {args[0]} intalled?')
		print(f'subprocess.SubprocessError {e}')
		return None
	str_info = info.decode('utf-8')
	return str_info.splitlines()

def get_monitor_geometries(divw=0,divh=0):
	"""
	use xrandr to get the geometry of the connected monitors
	HDMI-1 connected primary 3440x1440+0+0 (normal left inverted right x axis y axis) 797mm x 334mm
	:return: list of str of form 3440x1440+0+0
	:rtype: list[str]
	"""
	
	def devide(dw, dh,width, heigth):
		width, heigth = int(width), int(heigth)
		div_width  = width  // dw
		div_heigth = heigth // dh
		res = []
		for i in range(0, dw):
			for j in range(0, dh):
				t = (div_width, div_heigth, i * div_width, j * div_heigth)
				res.append(t)
		r = [str(x[0]) + 'x' + str(x[1]) + '+' + str(x[2]) + '+' + str(x[3]) for x in res]
		return r
	
	detected = []
	xrandr = service_call('xrandr')
	for line in xrandr:
		if ' connected ' in line:
			print(f'{line}')
			match = re.findall(r'((\d+)x(\d+)\+(\d+)\+(\d+))', line)
			detected.append(match[0][0])
	if divw == 0 and divh == 0:
		return detected
	if divw == 0:
		divw = 1
	elif divh == 0:
		divh = 1
	return devide(divw, divh, match[0][1], match[0][2])
	
